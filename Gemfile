source "https://rubygems.org"

# This gem is required to run Jekyll
gem "jekyll", "~> 3.10.0"

# These are common plugins for SEO and RSS feeds
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end

gem "github-pages", "~> 232", group: :jekyll_plugins

# If you want to use the default 'minima' theme
gem "minima", "~> 2.5"

# This helps Ruby handle your local server
gem "webrick", "~> 1.8"
